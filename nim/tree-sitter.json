        "nim",
        "nimble",
        "nims"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.6.2",
    "license": "MPL-2.0",
    "description": "Tree-sitter grammar for Nim",
    "authors": [
      {
        "name": "leorize"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-nim"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
