{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "gdshader",
      "camelcase": "Gdshader",
      "title": "Gdshader",
      "scope": "source.gdshader",
      "file-types": [
        "gdshader",
        "gdshaderinc"
      ],
      "class-name": "TreeSitterGdshader",
      "first_line_regex": "shader_type\\s+(?:s(?:ky|patial)|canvas_item|particle|fog)\\s*;",
      "content-regex": "void\\s+(?:vertex|f(?:ragment|og)|light|s(?:ky|tart)|process)\\s*\\(\\s*\\)\\s*{",
      "injection-regex": "^(gdshader)$",
      "highlights": "queries/highlights.scm",
      "locals": "queries/locals.scm",
      "tags": "queries/tags.scm"
    }
  ],
  "metadata": {
    "version": "0.4.0",
    "license": "MIT",
    "description": "A parser for the Godot Shader langage",
    "authors": [
      {
        "name": "Tayfun Bocek",
        "email": "tayfunbocek@live.ca",
        "url": "https://github.com/airblast-dev"
      }
    ],
    "links": {
      "repository": "https://github.com/airblast-dev/tree-sitter-gdshader"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
