{
  "grammars": [
    {
      "name": "@amaanq/func",
      "camelcase": "AmaanqFunc",
      "scope": "source.func",
      "path": ".",
      "file-types": [
        "fc"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "^(fc|func)$"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "FunC grammar for tree-sitter",
    "authors": [
      {
        "name": "akifoq"
      }
    ],
    "links": {
      "repository": "https://github.com/amaanq/tree-sitter-func"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
