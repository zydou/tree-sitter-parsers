{
  "grammars": [
    {
      "name": "m68k",
      "camelcase": "M68k",
      "scope": "source.m68k",
      "path": ".",
      "file-types": [
        "asm",
        "ASM",
        "s",
        "S",
        "i",
        "I"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.3.2",
    "license": "MIT",
    "description": "Motorola 68000 family assembly grammar for tree-sitter",
    "authors": [
      {
        "name": "Graham Bates"
      }
    ],
    "links": {
      "repository": "https://github.com/grahambates/tree-sitter-m68k"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
