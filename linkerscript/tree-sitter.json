{
  "grammars": [
    {
      "name": "linkerscript",
      "camelcase": "Linkerscript",
      "scope": "source.ld",
      "path": ".",
      "file-types": [
        "ld",
        "lds",
        "ldscript",
        "linkerscript"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injections": [
        "queries/injections.scm"
      ],
      "locals": [
        "queries/locals.scm"
      ],
      "injection-regex": "^(ld|linkerscript)"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "Linkerscript grammar for tree-sitter",
    "authors": [
      {
        "name": "Amaan Qureshi",
        "email": "amaanq12@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/amaanq/tree-sitter-linkerscript.git"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
