{
  "grammars": [
    {
      "name": "@elm-tooling/elm",
      "camelcase": "ElmToolingElm",
      "scope": "source.elm",
      "path": ".",
      "file-types": [
        "elm"
      ]
    }
  ],
  "metadata": {
    "version": "5.7.0",
    "license": "MIT",
    "description": "Tree sitter definitions for elm",
    "authors": [
      {
        "name": "Razze"
      }
    ],
    "links": {
      "repository": "https://github.com/elm-tooling/tree-sitter-elm"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
