{
  "grammars": [
    {
      "name": "ispc",
      "camelcase": "Ispc",
      "scope": "source.ispc",
      "path": ".",
      "file-types": [
        "ispc"
      ]
    }
  ],
  "metadata": {
    "version": "0.1.1",
    "license": "MIT",
    "description": "ISPC grammar for tree-sitter (based on C grammar)",
    "authors": [
      {
        "name": "Fabian Wermelinger"
      }
    ],
    "links": {
      "repository": "https://github.com/ispc/ispc.tree-sitter"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
