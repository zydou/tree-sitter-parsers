{
  "grammars": [
    {
      "name": "d",
      "camelcase": "D",
      "scope": "source.d",
      "path": ".",
      "file-types": [
        "d",
        "dd"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injections": [
        "queries/injections.scm"
      ],
      "tags": [
        "queries/tags.scm"
      ]
    }
  ],
  "metadata": {
    "version": "0.8.2",
    "license": "MIT",
    "description": "d grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-d"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
