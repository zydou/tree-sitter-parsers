{
  "grammars": [
    {
      "name": "rebase",
      "camelcase": "Rebase",
      "scope": "source.rebase",
      "path": ".",
      "file-types": [
        "git-rebase-todo"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "Tree-sitter grammar for git's interactive rebase TODO file",
    "authors": [
      {
        "name": "the-mikedavis"
      }
    ],
    "links": {
      "repository": "git+https://github.com/the-mikedavis/tree-sitter-rebase.git"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
