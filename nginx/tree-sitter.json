{
  "grammars": [
    {
      "name": "nginx",
      "camelcase": "Nginx",
      "scope": "source.YOUR_LANGUAGE_NAME",
      "path": ".",
      "file-types": null,
      "injection-regex": "^YOUR_LANGUAGE_NAME$"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "nginx grammar for tree-sitter",
    "authors": [
      {
        "name": "Vladimir Levin",
        "email": "opaozhub@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/opa-oz/tree-sitter-nginx"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
