{
  "grammars": [
    {
      "name": "forth",
      "camelcase": "Forth",
      "scope": "source.forth",
      "path": ".",
      "file-types": [
        "fs",
        "forth",
        "fth",
        "f",
        "4th"
      ]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Forth grammar for tree-sitter",
    "authors": [
      {
        "name": "Alexander Brevig"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-forth"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
