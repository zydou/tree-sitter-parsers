{
  "grammars": [
    {
      "name": "bitbake",
      "camelcase": "Bitbake",
      "scope": "source.bitbake",
      "path": ".",
      "file-types": [
        "bb",
        "bbclass"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injections": [
        "queries/injections.scm"
      ],
      "locals": [
        "queries/locals.scm"
      ],
      "injection-regex": "^(bb|bbclass)$"
    }
  ],
  "metadata": {
    "version": "1.1.0",
    "license": "MIT",
    "description": "BitBake grammar for tree-sitter",
    "authors": [
      {
        "name": "Amaan Qureshi",
        "email": "amaanq12@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/amaanq/tree-sitter-bitbake"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
