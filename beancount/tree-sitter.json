{
  "grammars": [
    {
      "name": "beancount",
      "camelcase": "Beancount",
      "scope": "source.beancount",
      "path": ".",
      "file-types": null,
      "injection-regex": "^beancount$"
    }
  ],
  "metadata": {
    "version": "2.3.3",
    "license": "MIT",
    "description": "a tree-sitter parser for the beancount syntax",
    "authors": [
      {
        "name": "Brian Ryall"
      }
    ],
    "links": {
      "repository": "git+https://bryall@github.com/bryall/tree-sitter-beancount.git"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
