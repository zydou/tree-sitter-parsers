{
  "grammars": [
    {
      "name": "leo",
      "camelcase": "Leo",
      "scope": "source.leo",
      "path": ".",
      "file-types": [
        "leo"
      ],
      "highlights": [
        "queries/highlights.scm"
      ]
    }
  ],
  "metadata": {
    "version": "1.0.1",
    "license": "MIT",
    "description": "Tree-sitter parser and highlighter for aleo.org leo language.",
    "authors": [
      {
        "name": "Robert Horvath"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-leo"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
