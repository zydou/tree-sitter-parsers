{
  "grammars": [
    {
      "name": "hoon",
      "camelcase": "Hoon",
      "scope": "source.hoon",
      "path": ".",
      "file-types": [
        "hoon"
      ]
    }
  ],
  "metadata": {
    "version": "0.0.2",
    "license": "ISC",
    "description": "Hoon parser written using the tree-sitter grammar.",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-hoon"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
