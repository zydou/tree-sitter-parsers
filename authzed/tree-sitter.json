{
  "grammars": [
    {
      "name": "authzed",
      "camelcase": "Authzed",
      "scope": "source.zed",
      "path": ".",
      "file-types": [
        "authzed",
        "zed"
      ]
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "Authzed grammer for tree-sitter",
    "authors": [
      {
        "name": "mleonidas"
      }
    ],
    "links": {
      "repository": "https://github.com/mleonidas/tree-sitter-authzed"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
