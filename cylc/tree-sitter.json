{
  "grammars": [
    {
      "name": "cylc",
      "camelcase": "Cylc",
      "scope": "source.cylc",
      "path": ".",
      "file-types": [
        "cylc",
        "rc"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "^cylc$"
    }
  ],
  "metadata": {
    "version": "0.2.0",
    "license": "MIT",
    "description": "Cylc grammar for tree-sitter",
    "authors": [
      {
        "name": "Elliot Fontaine",
        "email": "elliot.fontaine@gmail.com"
      }
    ],
    "links": {
      "repository": "git+https://github.com/elliotfontaine/tree-sitter-cylc.git"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
