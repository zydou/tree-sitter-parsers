{
  "grammars": [
    {
      "name": "hare",
      "camelcase": "Hare",
      "scope": "source.ha",
      "path": ".",
      "file-types": [
        "hare"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "^(hare|ha)$"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "Hare grammar for tree-sitter",
    "authors": [
      {
        "name": "Amaan Qureshi",
        "email": "amaanq12@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/amaanq/tree-sitter-hare"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
