{
  "grammars": [
    {
      "name": "csv",
      "camelcase": "Csv",
      "scope": "source.csv",
      "path": "csv",
      "file-types": [
        "csv"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "csv"
    },
    {
      "name": "csv",
      "camelcase": "Csv",
      "scope": "source.psv",
      "path": "psv",
      "file-types": [
        "psv"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "psv"
    },
    {
      "name": "csv",
      "camelcase": "Csv",
      "scope": "source.tsv",
      "path": "tsv",
      "file-types": [
        "tsv"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "tsv"
    }
  ],
  "metadata": {
    "version": "1.2.0",
    "license": "MIT",
    "description": "CSV, PSV, & TSV grammar for tree-sitter",
    "authors": [
      {
        "name": "Amaan Qureshi",
        "email": "amaanq12@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-csv"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
