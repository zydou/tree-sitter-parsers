{
  "grammars": [
    {
      "name": "faust",
      "camelcase": "Faust",
      "scope": "source.faust",
      "path": ".",
      "file-types": [
        "dsp"
      ],
      "highlights": [
        "queries/highlights.scm"
      ]
    }
  ],
  "metadata": {
    "version": "1.1.5",
    "license": "MIT",
    "description": "Tree-sitter grammar for the Faust audio programming language",
    "authors": [
      {
        "name": "Karl Hiner"
      }
    ],
    "links": {
      "repository": "git+https://github.com/khiner/tree-sitter-faust.git"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
