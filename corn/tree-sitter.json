{
  "grammars": [
    {
      "name": "corn",
      "camelcase": "Corn",
      "scope": "source.js",
      "path": ".",
      "file-types": [
        "corn"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "^corn$"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "corn grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-corn"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
