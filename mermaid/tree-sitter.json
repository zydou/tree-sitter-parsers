{
  "grammars": [
    {
      "name": "mermaid",
      "camelcase": "Mermaid",
      "scope": "source.mermaid",
      "path": ".",
      "file-types": [
        "mmd"
      ],
      "injection-regex": "mermaid|mmd"
    }
  ],
  "metadata": {
    "version": "0.0.2",
    "license": "MIT",
    "description": "Tree-sitter grammar for mermaid.js",
    "authors": [
      {
        "name": "monaqa"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-mermaid"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
