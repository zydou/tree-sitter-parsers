{
  "grammars": [
    {
      "name": "nickel",
      "camelcase": "Nickel",
      "scope": "source.ncl",
      "path": ".",
      "file-types": [
        "ncl",
        "nickel"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injection-regex": "^(ncl|nickel)$"
    }
  ],
  "metadata": {
    "version": "0.2.0",
    "license": "MIT",
    "description": "Nickel grammar for tree-sitter",
    "links": {
      "repository": "git+https://github.com/nickel-lang/tree-sitter-nickel.git"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
