{
  "grammars": [
    {
      "name": "gitignore",
      "camelcase": "Gitignore",
      "scope": "source.gitignore",
      "path": ".",
      "file-types": [
        ".gitignore",
        ".ignore",
        ".fdignore",
        ".rgignore"
      ]
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Gitignore grammar for tree-sitter",
    "authors": [
      {
        "name": "Shun Sambongi"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-gitignore"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
