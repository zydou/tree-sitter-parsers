      "path": ".",
      "file-types": null,
      "injection-regex": "^muttrc$"
    }
  ],
  "metadata": {
    "version": "0.0.6",
    "license": "MIT",
    "description": "Muttrc grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-muttrc"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
