{
  "grammars": [
    {
      "name": "gn",
      "camelcase": "Gn",
      "scope": "source.gn",
      "path": ".",
      "file-types": [
        "gn"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injections": [
        "queries/injections.scm"
      ],
      "injection-regex": "gn"
    }
  ],
  "metadata": {
    "version": "1.0.0",
    "license": "MIT",
    "description": "GN (Generate Ninja) grammar for tree-sitter",
    "authors": [
      {
        "name": "Amaan Qureshi",
        "email": "amaanq12@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/amaanq/tree-sitter-gn"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
