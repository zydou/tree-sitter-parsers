{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "jjdescription",
      "camelcase": "JjDescription",
      "title": "JJ Description",
      "scope": "source.jjdescription",
      "file-types": [
        "jjdescription"
      ],
      "injection-regex": "^jjdescription$",
      "class-name": "TreeSitterJjdescription"
    }
  ],
  "metadata": {
    "version": "1.0.3",
    "license": "MIT",
    "description": "Tree-sitter parser for `jj desc` buffers.",
    "authors": [
      {
        "name": "Riley Bruins",
        "email": "ribru17@gmail.com"
      }
    ],
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-jjdescription"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": false
  }
}
